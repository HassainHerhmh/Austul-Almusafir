generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Office {
  id              String     @id @default(cuid())
  name            String
  city            String
  phone           String
  status          String     @default("active")
  subscription    String     @default("trial")
  ledgerAccountId Int?
  /** نسبة عمولة المكتب من سعر التذكرة (مثلاً 10 = 10%) */
  commissionPercent Float    @default(0)
  createdAt       DateTime   @default(now())
  users           User[]
  customers       Customer[]
  bookings        Booking[]
  vouchers        Voucher[]
  campaignTrips   Trip[]    @relation("CampaignOffice")
  trackingAccess  TripOfficeTrackingAccess[]
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  name         String
  phone        String    @default("")
  role         String
  officeId     String?
  office       Office?   @relation(fields: [officeId], references: [id])
  /** ربط حساب تطبيق التتبع بسجل السائق */
  driverId     String?
  driver       Driver?   @relation(fields: [driverId], references: [id])
  active       Boolean   @default(true)
  /** صلاحيات الصفحات (عرض/إضافة/تعديل/حذف) — نفس أسلوب منصة الكروت */
  permissions  Json?
  bookings     Booking[] @relation("BookedBy")
  createdAt    DateTime  @default(now())

  @@index([driverId])
}

model Destination {
  id          String     @id @default(cuid())
  name        String
  /** سعر التذكرة لمنطقة الصعود/الوجهة عند التسعير حسب المنطقة */
  ticketPrice Float      @default(0)
  tripStops   TripStop[]
}

model VisaType {
  id   String @id @default(cuid())
  name String
}

model Bus {
  id          String @id @default(cuid())
  /** رقم الحافلة الداخلي (مثل 101) */
  busNumber   String @default("")
  plateNumber String @unique
  type        String
  /** سنة الموديل */
  year        String @default("")
  seats       Int
  status      String @default("available")
  trips       Trip[]
}

model Driver {
  id            String  @id @default(cuid())
  name          String
  phone         String
  /** رقم الهوية (كان مسمى رخصة سابقاً في الواجهة) */
  licenseNumber String
  nationality   String  @default("")
  role          String  @default("primary")
  active        Boolean @default(true)
  trips         Trip[]  @relation("TripDriver")
  users         User[]
}

model Trip {
  id                 String     @id @default(cuid())
  busId              String
  bus                Bus        @relation(fields: [busId], references: [id])
  driverId           String
  driver             Driver     @relation("TripDriver", fields: [driverId], references: [id])
  /** اسم السائق المعاون (إدخال مباشر، اختياري) */
  assistantName      String     @default("")
  /** جوال السائق المعاون (إدخال مباشر، اختياري) */
  assistantPhone     String     @default("")
  /** passenger = ركاب · campaign = حملة */
  tripKind           String     @default("passenger")
  /** مكتب/وكيل الحملة — يُقيَّد عليه إجمالي السعر عند فتح الرحلة */
  campaignOfficeId   String?
  campaignOffice     Office?    @relation("CampaignOffice", fields: [campaignOfficeId], references: [id])
  /** trip = سعر الرحلة · boarding = سعر منطقة الصعود (لرحلات الركاب) */
  pricingMode        String     @default("trip")
  date               String
  departureTime      String
  /** سعر التذكرة (ركاب) أو إجمالي سعر الحملة */
  price              Float
  status             String     @default("scheduled")
  stops              TripStop[]
  bookings           Booking[]
  location           TripLocation?
  trackingShares     TripTrackingShare[]
  officeTrackingAccess TripOfficeTrackingAccess[]
  createdAt          DateTime   @default(now())

  @@index([campaignOfficeId])
}

/** سماح أدمن لمكتب معيّن بتتبع رحلة معيّنة */
model TripOfficeTrackingAccess {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  officeId  String
  office    Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tripId, officeId])
  @@index([officeId])
  @@index([tripId])
}

/** رابط تتبع عام لرحلة — يُشارك بدون تسجيل دخول */
model TripTrackingShare {
  id        String   @id @default(cuid())
  token     String   @unique
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  label     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

/** آخر موقع GPS حي لكل رحلة */
model TripLocation {
  tripId    String   @id
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  speed     Float?
  heading   Float?
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model TripStop {
  id            String      @id @default(cuid())
  tripId        String
  trip          Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  point         String
  sortOrder     Int         @default(0)
}

model Customer {
  id             String    @id @default(cuid())
  name           String
  phone          String
  nationalId     String
  passportNumber String    @default("")
  officeId       String
  office         Office    @relation(fields: [officeId], references: [id])
  bookings       Booking[]
  createdAt      DateTime  @default(now())
}

model Booking {
  id             String    @id @default(cuid())
  tripId         String
  trip           Trip      @relation(fields: [tripId], references: [id])
  officeId       String
  office         Office    @relation(fields: [officeId], references: [id])
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  passengerName  String
  /** رقم التذكرة الظاهر للمسافر */
  ticketNumber   String    @default("")
  passportNumber String    @default("")
  /** نوع التأشيرة من قائمة الإدارة */
  visaTypeId     String    @default("")
  /** مدينة/محطة الانطلاق من محطات مسار الرحلة */
  boardingDestinationId String @default("")
  /** مدينة/محطة الوصول من محطات مسار الرحلة */
  arrivalDestinationId  String @default("")
  seatNumber     Int
  price          Float
  paymentMethod  String    @default("cash")
  notes          String    @default("")
  status         String    @default("confirmed")
  bookedAt       DateTime  @default(now())
  bookedById     String
  bookedBy       User      @relation("BookedBy", fields: [bookedById], references: [id])
  vouchers       Voucher[]

  @@index([officeId])
  @@index([tripId])
  @@index([tripId, seatNumber])
}

model Voucher {
  id               String   @id @default(cuid())
  officeId         String
  office           Office   @relation(fields: [officeId], references: [id])
  type             String
  amount           Float
  description      String
  date             String
  relatedBookingId String?
  relatedBooking   Booking? @relation(fields: [relatedBookingId], references: [id])
  createdAt        DateTime @default(now())
}

model Account {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  nameAr              String
  nameEn              String?
  parentId            Int?
  accountLevel        String
  financialStatement  String?
  createdAt           DateTime @default(now())
  journalLines        JournalLine[]
}

model JournalLine {
  id            Int      @id @default(autoincrement())
  referenceId   Int
  referenceType String
  journalDate   String
  accountId     Int
  account       Account  @relation(fields: [accountId], references: [id])
  debit         Float    @default(0)
  credit        Float    @default(0)
  currencyCode  String?
  currencyName  String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([accountId])
  @@index([referenceType, referenceId])
}

model AppSetting {
  key   String @id
  value Json
}
